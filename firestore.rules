rules_version = '2';
// Trigger rules deployment for both primary and backup environments
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getRole(uid) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data.role
        : 'anonymous';
    }

    // Lowercased role of the current user. Self-guarding (returns 'anonymous'
    // when unauthenticated) so callers never dereference a null request.auth.
    function roleName() {
      return isSignedIn() ? getRole(request.auth.uid).lower() : 'anonymous';
    }

    function isSuperAdminRole(role) {
      return role == 'superadmin'
        || role == 'SUPERADMIN'
        || role == 'superAdmin'
        || role == 'super_admin'
        || role == 'super-admin'
        || role == 'super admin'
        || role == 'owner'
        || role == 'OWNER'
        || role == 'Owner';
    }

    function isBootstrapSuperAdminEmail(email) {
      return email is string
        && email.matches('(?i)^kem\\.phearum@gmail\\.com$');
    }

    function isOwnEmail(email) {
      return email is string
        && isSignedIn()
        && (
          email == request.auth.token.email
          || (
            isBootstrapSuperAdminEmail(email)
            && isBootstrapSuperAdminEmail(request.auth.token.email)
          )
        );
    }

    function isAdminRole(role) {
      return role == 'admin'
        || role == 'ADMIN'
        || role == 'administrator'
        || role == 'ADMINISTRATOR'
        || isSuperAdminRole(role);
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        isBootstrapSuperAdminEmail(request.auth.token.email)
        || roleName() == 'superadmin'
        || roleName() == 'owner'
      );
    }

    function isAdmin() {
      return roleName() == 'admin'
        || roleName() == 'administrator'
        || getBaseRole(roleName()) == 'admin'
        || isSuperAdmin();
    }

    function isStaff() {
      return isSignedIn()
        && (
          isBootstrapSuperAdminEmail(request.auth.token.email)
          || (roleName() != 'anonymous'
             && roleName() != 'pending'
             && roleName() != '')
        );
    }

    function isEditor() {
      return roleName() == 'editor'
        || roleName() == 'writer'
        || getBaseRole(roleName()) == 'editor'
        || isAdmin();
    }

    // ============================================================
    // Server-side RBAC enforcement (mirrors src/utils/permissions.js)
    // ------------------------------------------------------------
    // The admin UI computes granular permissions client-side from the
    // `rolePermissions` collection. Those checks are advisory only — the
    // rules below are the authority. Custom roles are resolved by reading
    // their role-keyed rolePermissions document; built-in roles fall back
    // to tier defaults so they keep working even without a permission doc.
    // ============================================================
    function hasPermDocFor(role) {
      return exists(/databases/$(database)/documents/rolePermissions/$(role));
    }

    function permDocFor(role) {
      return get(/databases/$(database)/documents/rolePermissions/$(role)).data;
    }

    // A baseRole tier grants ALL actions on the modules it covers, matching
    // the inheritance branch in isActionAllowed(): admin -> all content
    // modules; editor -> blog & projects only.
    function baseTierCanContent(base, moduleName) {
      return base == 'admin'
        || (base == 'editor' && (moduleName == 'blog' || moduleName == 'projects'));
    }

    // Does a custom role's permission doc grant write capability on a module?
    function permWritesModule(perm, moduleName) {
      return moduleName in perm.get('allowedTabs', [])
        && (
          baseTierCanContent(perm.get('baseRole', 'pending'), moduleName)
          || perm.get('allowedActions', {}).get(moduleName, [])
              .hasAny(['create', 'edit', 'delete', 'feature', 'toggle_visibility'])
        );
    }

    // Module-level write capability. Used for content collections whose
    // recursive {document=**} match also covers the `history` subcollection,
    // so we gate at the module level (any write action) rather than per-op.
    function canWriteModule(moduleName) {
      return isSignedIn() && (
        isAdmin()
        || (
          (roleName() == 'editor' || roleName() == 'writer')
          && (moduleName == 'blog' || moduleName == 'projects')
        )
        || (
          hasPermDocFor(roleName())
          && permWritesModule(permDocFor(roleName()), moduleName)
        )
      );
    }

    function canViewMessages() {
      return isSignedIn() && (
        isAdmin()
        || (
          hasPermDocFor(roleName())
          && 'messages' in permDocFor(roleName()).get('allowedTabs', [])
        )
      );
    }

    function permManagesMessages(perm) {
      return 'messages' in perm.get('allowedTabs', [])
        && (
          perm.get('baseRole', 'pending') == 'admin'
          || 'delete' in perm.get('allowedActions', {}).get('messages', [])
        );
    }

    function canManageMessages() {
      return isSignedIn() && (
        isAdmin()
        || (
          hasPermDocFor(roleName())
          && permManagesMessages(permDocFor(roleName()))
        )
      );
    }

    function isVisitPayloadValid() {
      return request.resource.data.keys().hasOnly([
        'sessionId', 'path', 'date', 'userAgent', 'device', 'browser', 'os',
        'isReturning', 'country', 'countryCode', 'city', 'ip', 'referrer',
        'duration', 'timestamp'
      ])
      && request.resource.data.sessionId is string
      && request.resource.data.sessionId.size() > 0
      && request.resource.data.sessionId.size() <= 128
      && request.resource.data.path is string
      && request.resource.data.path.size() > 0
      && request.resource.data.path.size() <= 512
      && request.resource.data.date is string
      && request.resource.data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
      && request.resource.data.userAgent is string
      && request.resource.data.userAgent.size() <= 1024
      && request.resource.data.device is string
      && request.resource.data.device.size() <= 24
      && request.resource.data.browser is string
      && request.resource.data.browser.size() <= 80
      && request.resource.data.os is string
      && request.resource.data.os.size() <= 80
      && request.resource.data.isReturning is bool
      && request.resource.data.country is string
      && request.resource.data.country.size() <= 100
      && request.resource.data.countryCode is string
      && request.resource.data.countryCode.size() <= 3
      && request.resource.data.city is string
      && request.resource.data.city.size() <= 120
      && request.resource.data.ip is string
      && request.resource.data.ip.size() <= 64
      && request.resource.data.referrer is string
      && request.resource.data.referrer.size() <= 1024
      && (!request.resource.data.keys().hasAny(['duration'])
        || (request.resource.data.duration is int
            && request.resource.data.duration >= 0
            && request.resource.data.duration <= 86400))
      && request.resource.data.timestamp is timestamp;
    }

    function isVisitDurationUpdateValid() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['duration'])
      && request.resource.data.duration is int
      && request.resource.data.duration >= 0
      && request.resource.data.duration <= 86400;
    }

    function isDailyUsagePayloadValid() {
      return request.resource.data.keys().hasOnly(['reads', 'writes', 'deletes', 'lastUpdated'])
      && request.resource.data.reads is int
      && request.resource.data.writes is int
      && request.resource.data.deletes is int
      && request.resource.data.reads >= 0
      && request.resource.data.writes >= 0
      && request.resource.data.deletes >= 0
      && request.resource.data.lastUpdated is timestamp;
    }

    function isActivityLogPayloadValid() {
      return request.resource.data.keys().hasOnly(['type', 'label', 'count', 'user', 'time', 'details'])
      && request.resource.data.type is string
      && request.resource.data.label is string
      && request.resource.data.count is int
      && request.resource.data.count >= 0
      && request.resource.data.user is string
      && request.resource.data.time is timestamp;
    }

    // ============================================================
    // Schema Validation Helpers
    // ============================================================
    function isLocalizedField(field) {
      return field is map && field.keys().hasAny(['en']) && field.en is string;
    }
    
    function hasSystemFields(data) {
      return (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp)
          && (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp)
          && (!data.keys().hasAny(['createdBy']) || data.createdBy is string)
          && (!data.keys().hasAny(['updatedBy']) || data.updatedBy is string);
    }

    function isProjectPayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['title', 'description', 'techStack', 'githubUrl', 'liveUrl', 'slug', 'content', 'visible', 'publishedAt', 'status', 'featured', 'imageUrl', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy', 'problem', 'solution', 'architecture', 'impact', 'galleryUrls'])
      && (!data.keys().hasAny(['title']) || isLocalizedField(data.title))
      && (!data.keys().hasAny(['description']) || data.description is map)
      && (!data.keys().hasAny(['content']) || data.content is map)
      && (!data.keys().hasAny(['techStack']) || data.techStack is list)
      && (!data.keys().hasAny(['slug']) || data.slug is string)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['featured']) || data.featured is bool)
      && hasSystemFields(data);
    }
    
    function isExperiencePayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['company', 'role', 'startDate', 'startMonthYear', 'endDate', 'endMonthYear', 'period', 'current', 'description', 'visible', 'order', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy', 'companyLogoUrl', 'employmentType', 'location', 'keyResponsibilities', 'majorAchievements', 'technologiesUsed', 'relatedProjects'])
      && (!data.keys().hasAny(['company']) || isLocalizedField(data.company))
      && (!data.keys().hasAny(['role']) || isLocalizedField(data.role))
      && (!data.keys().hasAny(['current']) || data.current is bool)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['order']) || data.order is number)
      && hasSystemFields(data);
    }
    
    function isSkillPayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['name', 'description', 'category', 'level', 'slug', 'visible', 'featured', 'order', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy', 'yearsOfExperience', 'iconUrl', 'relatedProjects', 'relatedCertifications'])
      && (!data.keys().hasAny(['name']) || isLocalizedField(data.name))
      && (!data.keys().hasAny(['slug']) || data.slug is string)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['featured']) || data.featured is bool)
      && (!data.keys().hasAny(['order']) || data.order is number)
      && hasSystemFields(data);
    }
    
    function isCertificatePayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['name', 'description', 'organization', 'issueDate', 'expiryDate', 'credentialId', 'url', 'slug', 'visible', 'featured', 'order', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy', 'badgeUrl', 'skillsCovered'])
      && (!data.keys().hasAny(['name']) || isLocalizedField(data.name))
      && (!data.keys().hasAny(['slug']) || data.slug is string)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['featured']) || data.featured is bool)
      && (!data.keys().hasAny(['order']) || data.order is number)
      && hasSystemFields(data);
    }
    
    function isEducationPayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['school', 'degree', 'fieldOfStudy', 'startDate', 'startYear', 'endDate', 'endYear', 'period', 'current', 'description', 'visible', 'order', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy', 'type'])
      && (!data.keys().hasAny(['school']) || isLocalizedField(data.school))
      && (!data.keys().hasAny(['degree']) || isLocalizedField(data.degree))
      && (!data.keys().hasAny(['current']) || data.current is bool)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['order']) || data.order is number)
      && hasSystemFields(data);
    }
    
    function isPostPayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['title', 'excerpt', 'content', 'slug', 'tags', 'visible', 'publishedAt', 'status', 'featured', 'coverImage', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy', 'views'])
      && (!data.keys().hasAny(['title']) || isLocalizedField(data.title))
      && (!data.keys().hasAny(['slug']) || data.slug is string)
      && (!data.keys().hasAny(['tags']) || data.tags is list)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['featured']) || data.featured is bool)
      && (!data.keys().hasAny(['views']) || data.views is int)
      && hasSystemFields(data);
    }
    
    function isAwardPayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['title', 'organization', 'description', 'issueDate', 'link', 'visible', 'featured', 'order', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy'])
      && (!data.keys().hasAny(['title']) || isLocalizedField(data.title))
      && (!data.keys().hasAny(['organization']) || data.organization is string)
      && (!data.keys().hasAny(['description']) || data.description is string)
      && (!data.keys().hasAny(['link']) || data.link is string)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['featured']) || data.featured is bool)
      && (!data.keys().hasAny(['order']) || data.order is number)
      && hasSystemFields(data);
    }
    
    function isPublicationPayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['title', 'publisher', 'description', 'publishDate', 'link', 'visible', 'featured', 'order', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy'])
      && (!data.keys().hasAny(['title']) || isLocalizedField(data.title))
      && (!data.keys().hasAny(['publisher']) || data.publisher is string)
      && (!data.keys().hasAny(['description']) || data.description is string)
      && (!data.keys().hasAny(['link']) || data.link is string)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['featured']) || data.featured is bool)
      && (!data.keys().hasAny(['order']) || data.order is number)
      && hasSystemFields(data);
    }
    
    function isSpeakingPayloadValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['title', 'eventName', 'location', 'description', 'date', 'link', 'visible', 'featured', 'order', 'createdAt', 'updatedAt', 'createdBy', 'updatedBy'])
      && (!data.keys().hasAny(['title']) || isLocalizedField(data.title))
      && (!data.keys().hasAny(['eventName']) || data.eventName is string)
      && (!data.keys().hasAny(['location']) || data.location is string)
      && (!data.keys().hasAny(['description']) || data.description is string)
      && (!data.keys().hasAny(['link']) || data.link is string)
      && (!data.keys().hasAny(['visible']) || data.visible is bool)
      && (!data.keys().hasAny(['featured']) || data.featured is bool)
      && (!data.keys().hasAny(['order']) || data.order is number)
      && hasSystemFields(data);
    }

    // Audit log integrity: append-only, schema-pinned, and the recorded
    // email must match the authenticated principal (no spoofing other users).
    function isAuditLogPayloadValid() {
      return request.resource.data.keys().hasOnly([
        'email', 'ipAddress', 'country', 'city', 'userAgent',
        'deviceType', 'sessionId', 'details', 'status', 'reason', 'timestamp'
      ])
      && request.resource.data.email is string
      && request.auth.token.email is string
      && request.resource.data.email.lower() == request.auth.token.email.lower()
      && (request.resource.data.status == 'success' || request.resource.data.status == 'failure');
    }

    // writes are also gated by payload schemas
    match /content/contact {
      allow write: if canWriteModule('communication');
    }
    match /content/resume {
      allow write: if canWriteModule('resume');
    }
    match /content/{document=**} {
      allow read;
      allow write: if canWriteModule('general'); // Content schema is dynamic, so no strict shape
    }

    match /projects/{document=**} {
      allow read;
      allow write: if canWriteModule('projects') && isProjectPayloadValid();
    }

    match /experience/{document=**} {
      allow read;
      allow write: if canWriteModule('experience') && isExperiencePayloadValid();
    }

    match /skills/{document=**} {
      allow read;
      allow write: if canWriteModule('skills') && isSkillPayloadValid();
    }

    match /certificates/{document=**} {
      allow read;
      allow write: if canWriteModule('certificates') && isCertificatePayloadValid();
    }

    match /education/{document=**} {
      allow read;
      allow write: if canWriteModule('education') && isEducationPayloadValid();
    }

    match /awards/{document=**} {
      allow read;
      allow write: if canWriteModule('awards') && isAwardPayloadValid();
    }

    match /publications/{document=**} {
      allow read;
      allow write: if canWriteModule('publications') && isPublicationPayloadValid();
    }

    match /speaking/{document=**} {
      allow read;
      allow write: if canWriteModule('speaking') && isSpeakingPayloadValid();
    }

    // Application Settings (Logo, Page Title, Audit Log Config, etc.)
    match /settings/{document=**} {
      allow read;
      allow write: if isSuperAdmin();
    }

    // Blog Posts Rules
    match /posts/{document=**} {
      allow read;
      allow write: if canWriteModule('blog') && isPostPayloadValid();
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
                    && request.resource.data.views == resource.data.get('views', 0) + 1
                    && request.resource.data.views is int;
    }

    // Messages: contact submissions are written via Cloud Functions (Admin
    // SDK bypasses rules). Direct client access is restricted to roles that
    // are actually granted the messages module — not every signed-in staffer.
    match /messages/{document=**} {
      allow create: if isAdmin();
      allow read:   if canViewMessages();
      allow update: if canManageMessages();
      allow delete: if canManageMessages();
    }

    // Users: Highly restricted access
    match /users/{userId} {
      // 1. IDENTITY RULE: Users can always read their own document (MUST be first, 0 external calls)
      allow read: if isSignedIn() && request.auth.uid == userId;

      // 2. BOOTSTRAP RULE: Bootstrap super admin has full access (0 external calls)
      allow read, write: if isBootstrapSuperAdminEmail(request.auth.token.email);

      // 3. ADMIN READ: Use direct field access if possible, or skip to avoid recursive loops.
      // We block generic 'isAdmin()' here to prevent the infinite recursion through 'getRole'.
      // If a superadmin (non-bootstrap) needs to manage users, they use the bootstrap admin for now.

      // Users can ONLY update safe fields (like displayName) on their own profile.
      // They CANNOT modify role, isActive, or email.
      // Bootstrap super admin email may self-promote role to superadmin once.
      allow update: if isSignedIn()
                    && (
                      request.auth.uid == userId
                      || (
                        resource.data.email is string
                        && isOwnEmail(resource.data.email)
                      )
                    )
                    && (
                      !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'isActive', 'email', 'createdAt'])
                       || (
                        isBootstrapSuperAdminEmail(request.auth.token.email)
                        && isOwnEmail(request.resource.data.email)
                        && request.resource.data.role == 'superadmin'
                        && request.resource.data.isActive == true
                      )
                    );

      // Secure creation: role is pending by default. Bootstrap super admin email
      // can create itself as superadmin on first sign-in.
      allow create: if isSignedIn()
                    && (
                        request.auth.uid == userId
                        || isBootstrapSuperAdminEmail(request.auth.token.email)
                    )
                    && (
                      request.resource.data.role == 'pending'
                      || (
                        request.resource.data.role == 'superadmin'
                        && isBootstrapSuperAdminEmail(request.auth.token.email)
                      )
                    )
                    && request.resource.data.isActive == true
                    && isOwnEmail(request.resource.data.email);

      // Support for existing email-based queries (read and delete for own record)
      allow read, delete: if isSignedIn() && isOwnEmail(resource.data.email);
    }

    // Role Permissions: Superadmin writes; staff can read (drives the admin UI).
    // Pending/anonymous users have no need to enumerate the privilege model.
    match /rolePermissions/{document=**} {
      allow read: if isStaff();
      allow write: if isSuperAdmin();
    }

    // Login Audit Trail: authenticated users may append schema-validated logs
    // for their OWN email only. Logs are immutable; superadmins read/prune them.
    match /auditLogs/{document=**} {
      allow create: if isSignedIn() && isAuditLogPayloadValid();
      allow read, delete: if isSuperAdmin();
      allow update: if false;
    }

    // Analytics/Visits Tracking
    // NOTE: client-side creation is disabled to protect against quota exhaustion.
    // Ingestion is routed securely through the /api/analytics endpoint which
    // enforces strict IP-based rate limits.
    match /visits/{document=**} {
      allow create: if false;
      allow read, delete: if isAdmin();
      allow update: if isStaff();
    }

    // Global Activity Tracker
    match /dailyUsage/{date} {
      allow read: if isAdmin();
      allow create: if isStaff() && isDailyUsagePayloadValid();
      allow update: if isStaff()
                    && isDailyUsagePayloadValid()
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['reads', 'writes', 'deletes', 'lastUpdated']);
      allow delete: if isSuperAdmin();

      match /logs/{logId} {
        allow read, delete: if isAdmin();
        allow create: if isStaff() && isActivityLogPayloadValid();
      }
    }

    // Logs Collection Group
    match /{path=**}/logs/{logId} {
      allow read, delete: if isAdmin();
      allow create: if isStaff() && isActivityLogPayloadValid();
    }
  }
}
