rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for content, projects, experience, and posts
    match /content/{document=**} { allow read; allow write: if request.auth != null; }
    match /projects/{document=**} { allow read; allow write: if request.auth != null; }
    match /experience/{document=**} { allow read; allow write: if request.auth != null; }
    
    // Blog Posts Rules
    match /posts/{document=**} { 
      allow read; 
      allow write: if request.auth != null; 
    }

    // Messages: Public can write (send), only Admin can read
    match /messages/{document=**} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt']);
      allow read, update, delete: if request.auth != null;
    }

    // Users: Highly restricted access
    match /users/{document=**} {
      // 1. Superadmin (kem.phearum@gmail.com) has full read/write access to manage all users.
      // 2. Regular users can only read and update their *own* user document (where the email matches).
      // 3. New users can create their initial 'pending' record.
      allow read, write: if request.auth != null && request.auth.token.email == 'kem.phearum@gmail.com';
      allow read, update: if request.auth != null && resource.data.email == request.auth.token.email;
      allow create: if request.auth != null && request.resource.data.email == request.auth.token.email;
    }

    // Role Permissions: Superadmin writes; all authenticated users can read
    match /rolePermissions/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'kem.phearum@gmail.com';
    }

    // Login Audit Trail: Any authenticated user can append logs; only Superadmin can view/clear them
    match /auditLogs/{document=**} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && request.auth.token.email == 'kem.phearum@gmail.com';
      allow update: if false; // Logs should be immutable
    }

    // Analytics/Visits Tracking: Anyone can log a visit, only admin/superadmin can read
    match /visits/{document=**} {
      allow create;
      allow read, delete, update: if request.auth != null;
    }
  }
}
