rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'anonymous';
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (request.auth.token.email == 'kem.phearum@gmail.com' || getRole() == 'superadmin');
    }
    
    function isAdmin() {
      return isSignedIn() && (getRole() == 'admin' || isSuperAdmin());
    }
    
    function isEditor() {
      return isSignedIn() && (getRole() == 'editor' || isAdmin());
    }

    // Allow public read for content, projects, experience, and posts
    match /content/{document=**} { 
      allow read; 
      allow write: if isAdmin(); 
    }
    
    match /projects/{document=**} { 
      allow read; 
      allow write: if isEditor(); 
    }
    
    match /experience/{document=**} { 
      allow read; 
      allow write: if isAdmin(); 
    }
    
    // Application Settings (Logo, Page Title, Audit Log Config, etc.)
    match /settings/{document=**} {
      allow read;
      allow write: if isSuperAdmin();
    }

    // Blog Posts Rules
    match /posts/{document=**} { 
      allow read; 
      allow write: if isEditor(); 
    }

    // Messages: Public can write (send), only Admin can read/manage
    match /messages/{document=**} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt']);
      allow read, update, delete: if isAdmin();
    }

    // Users: Highly restricted access
    match /users/{userId} {
      // Superadmin has full access
      allow read, write: if isSuperAdmin();
      
      // Users can read their own profile (assuming UID-keyed)
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Users can ONLY update safe fields (like displayName) on their own profile.
      // They CANNOT modify role, isActive, or email.
      allow update: if isSignedIn() 
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'isActive', 'email']);
      
      // Secure creation: role must be 'pending', isActive must be true, and email must match auth
      allow create: if isSignedIn() 
                    && request.auth.uid == userId
                    && request.resource.data.role == 'pending'
                    && request.resource.data.isActive == true
                    && request.resource.data.email == request.auth.token.email;
      
      // Support for existing email-based queries (read and delete for own record)
      allow read, delete: if isSignedIn() && resource.data.email == request.auth.token.email;
    }

    // Role Permissions: Superadmin writes; all authenticated users can read
    match /rolePermissions/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Login Audit Trail: Any authenticated user can append logs; only Admin can view
    match /auditLogs/{document=**} {
      allow create: if isSignedIn();
      allow read, write: if isSuperAdmin();
    }

    // Analytics/Visits Tracking: Anyone can log a visit, only admin can read
    match /visits/{document=**} {
      allow create;
      allow read, delete, update: if isAdmin();
    }

    // Global Activity Tracker
    match /dailyUsage/{date} {
      allow read, create: if true;
      allow update: if true 
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['reads', 'writes', 'deletes', 'lastUpdated']);
      allow delete: if isAdmin();
      
      match /logs/{logId} {
        allow read, delete: if isAdmin();
        allow create: if true;
      }
    }
      
    // Logs Collection Group
    match /{path=**}/logs/{logId} {
      allow read, delete: if isAdmin();
      allow create: if true;
    }
  }
}
